{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug Cucumber - todas las features",
      "request": "launch",
      "mainClass": "io.cucumber.core.cli.Main",
      "projectName": "patito-selenium-tests",
      "cwd": "${workspaceFolder}",
      "classPaths": [
        "$Auto",
        "$Test"
      ],
      "args": [
        "--plugin", "pretty",
        "--plugin", "html:build/reports/cucumber/vscode.html",
        "--plugin", "json:build/reports/cucumber/vscode.json",
        "--plugin", "junit:build/reports/cucumber/vscode.xml",
        "--plugin", "io.qameta.allure.cucumber7jvm.AllureCucumber7Jvm",
        "--glue", "bo.juezvirtual.automation.steps",
        "src/test/resources/features"
      ],
      "vmArgs": "-Denv=dev -Dallure.results.directory=build/allure-results",
      "console": "integratedTerminal"
    },
    {
      "type": "java",
      "name": "Debug Cucumber - tag",
      "request": "launch",
      "mainClass": "io.cucumber.core.cli.Main",
      "projectName": "patito-selenium-tests",
      "cwd": "${workspaceFolder}",
      "classPaths": [
        "$Auto",
        "$Test"
      ],
      "args": [
        "--plugin", "pretty",
        "--plugin", "html:build/reports/cucumber/vscode-tag.html",
        "--plugin", "json:build/reports/cucumber/vscode-tag.json",
        "--plugin", "junit:build/reports/cucumber/vscode-tag.xml",
        "--plugin", "io.qameta.allure.cucumber7jvm.AllureCucumber7Jvm",
        "--glue", "bo.juezvirtual.automation.steps",
        "--tags", "${input:cucumberTags}",
        "src/test/resources/features"
      ],
      "vmArgs": "-Denv=dev -Dallure.results.directory=build/allure-results",
      "console": "integratedTerminal"
    },
    {
      "type": "java",
      "name": "Attach Gradle Cucumber Debug (:5005)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "preLaunchTask": "Gradle: executeBDDTests --debug-jvm"
    }
  ],
  "inputs": [
    {
      "id": "cucumberTags",
      "type": "promptString",
      "description": "Tag expression de Cucumber. Ej: @smoke, not @wip, @login and not @slow",
      "default": "@smoke"
    }
  ]
}
